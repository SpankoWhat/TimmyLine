data/
*.db
*.db-journal

# IDE / OS junk
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# Git
.git
.gitignore

# Plans and docs (not needed in the image)
plans/
DatabaseERD.drawio

# Host-only scripts
init-db.sh
