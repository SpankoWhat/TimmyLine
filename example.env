# Authentication Environment Variables

# Optional: runtime credential injection from AWS Secrets Manager.
# When TIMMYLINE_AWS_SECRET_ID is set, the helper script can load a JSON secret
# and export its keys as environment variables at process start.
# TIMMYLINE_AWS_SECRET_REGION can be omitted if AWS_REGION/AWS_DEFAULT_REGION exists.
TIMMYLINE_AWS_SECRET_ID=""
TIMMYLINE_AWS_SECRET_REGION=""

# Session secret (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Trust host in production (required for Auth.js)
AUTH_TRUST_HOST=true

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft Entra ID (Azure AD)
MICROSOFT_ENTRA_ID_CLIENT_ID=""
MICROSOFT_ENTRA_ID_CLIENT_SECRET=""
MICROSOFT_ENTRA_ID_TENANT_ID=""
MICROSOFT_ENTRA_ID_API_AUDIENCE=""

# GitHub OAuth (optional, for developer convenience)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""