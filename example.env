# Authentication Environment Variables

# Session secret (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Trust host in production (required for Auth.js)
AUTH_TRUST_HOST=true

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft Entra ID (Azure AD)
MICROSOFT_ENTRA_ID_CLIENT_ID=""
MICROSOFT_ENTRA_ID_CLIENT_SECRET=""
MICROSOFT_ENTRA_ID_TENANT_ID=""

# GitHub OAuth (optional, for developer convenience)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Filepath definitions
# Development: absolute path to your local DB
# Production: relative path or Docker volume path
DATABASE_URL="./data/timmyLine.db"
LOG_FILEPATH="./data/timmyLine.log"
LOG_WRITETOPATH=false

# Server port (production only — dev uses Vite's default 5173)
PORT=3000

# Application origin URL
# Development: http://localhost:5173
# Production:  http://localhost:3000 (or your real domain)
ORIGIN="http://localhost:5173"